# Rename this file to .env and fill in values

# Superset
SUPERSET_URL=https://bitool-hn2.zingplay.com
SUPERSET_SESSION=your_session_cookie_here
SUPERSET_DB_ID=1   # ClickHouse database ID in Superset (check SQL Lab URL)

# Telegram Bot
# 1. Chat with @BotFather on Telegram → /newbot → get token
# 2. Add bot to group/channel, send a message
# 3. Get chat_id: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Anthropic Claude API
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your_api_key_here
